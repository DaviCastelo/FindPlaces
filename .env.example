ENABLE_GRID_SEARCH=true
SEARCH_GRID_MAX_CELLS=4
SEARCH_MAX_AREAS=4
FALLBACK_QUERY_LIMIT=60
FALLBACK_MAX_QUERIES=4
SCRAPE_MAX_PAGES=3
